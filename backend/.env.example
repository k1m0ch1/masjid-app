# Backend Environment Variables
# Copy this to .env and fill with your actual values

# Database
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_JWT_SECRET=YOUR_JWT_SECRET
SUPABASE_INVITE_REDIRECT_URL=https://yourdomain.com/auth/callback

# WhatsApp (go-whatsapp-web-multidevice)
WA_BASE_URL=http://your-wa-server:8005
WA_USER=your_wa_username
WA_PASS=your_wa_password

# Google OAuth (via Supabase)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Redis (cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# API Settings
API_V1_PREFIX=/api/v1
PROJECT_NAME="Masjid Administration System"
DEBUG=false
ALLOWED_ORIGINS=https://yourdomain.com

# Security
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# WARNING:
# - NEVER commit .env to git
# - SERVICE_ROLE_KEY bypasses RLS - keep it SECRET
# - Only expose ANON_KEY in frontend (with RLS enabled)
