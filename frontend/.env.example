# Frontend Environment Variables
# Copy this to .env and fill with your actual values

# Backend API URL
VITE_API_BASE_URL=https://yourdomain.com/api/v1

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://<your-supabase-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Note:
# - SUPABASE_ANON_KEY is safe to expose in frontend code (with RLS enabled)
# - Make sure Row Level Security (RLS) is enabled on all Supabase tables
# - NEVER commit .env file to git
